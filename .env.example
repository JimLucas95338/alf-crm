# Postgres (Neon/Vercel Postgres/Supabase). For local dev, use a Neon dev branch.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Shared team password every teammate uses to sign in.
TEAM_PASSWORD="changeme"

# 32+ random chars to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET="generate-a-random-32char-string-here"
